# --- AI ---
AI_API_KEY=sk-...
AI_API_URL=https://api.openai.com/v1
LITELLM_MODEL=openai/gpt-4o

# --- Discord Bot (REST API; no discord.py needed) ---
DISCORD_BOT_TOKEN=
DISCORD_USER_ID=

# --- Database ---
# Defaults to data/stock.db inside the project
DATABASE_PATH=data/stock.db

# --- Authentication & CORS (Security) ---
# Set a secure password to protect the Web UI. If empty, Web UI auth is disabled.
APP_PASSWORD=
# Set a secure API key to protect API endpoints (/api/...). If empty, API auth is disabled.
API_KEY=
# Comma-separated list of allowed CORS origins (defaults to localhost)
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
